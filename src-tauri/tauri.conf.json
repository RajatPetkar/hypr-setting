{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Hypr Settings",
  "version": "0.1.0",
  "identifier": "io.hyprsettings.desktop",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Hypr Settings",
        "width": 1280,
        "height": 820,
        "minWidth": 980,
        "minHeight": 680
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": [
          "$HOME/Pictures/Wallpapers/**",
          "$HOME/Pictures/wallpapers/**",
          "$HOME/.config/hypr/wallpapers/**"
        ]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": ["deb", "rpm"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png"
    ],
    "category": "Utility",
    "shortDescription": "Hyprland settings control center",
    "longDescription": "A desktop settings application for managing Hyprland configuration files safely.",
    "linux": {
      "deb": {
        "depends": ["libwebkit2gtk-4.1-0", "hyprland"]
      }
    }
  }
}
